
// errno.win32.h.c3

// errno(), 
// get_fault()

module c::errno @if(env::WIN32);

extern fn long errno() @cname("GetLastError");
extern fn void set_errno(long err) @cname("SetLastError");

fn fault get_fault()
{
    return errno_to_fault(errno());
}

