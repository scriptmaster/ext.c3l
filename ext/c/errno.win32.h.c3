fn fault errno_to_fault(long err)
{
  switch (err) {
    case ERROR_SUCCESS: return F_SUCCESS;
    case ERROR_INVALID_FUNCTION: return F_INVALID_FUNCTION;
    case ERROR_FILE_NOT_FOUND: return F_FILE_NOT_FOUND;
    case ERROR_PATH_NOT_FOUND: return F_PATH_NOT_FOUND;
    case ERROR_TOO_MANY_OPEN_FILES: return F_TOO_MANY_OPEN_FILES;
    case ERROR_ACCESS_DENIED: return F_ACCESS_DENIED;
    case ERROR_INVALID_HANDLE: return F_INVALID_HANDLE;
    case ERROR_ARENA_TRASHED: return F_ARENA_TRASHED;
    case ERROR_NOT_ENOUGH_MEMORY: return F_NOT_ENOUGH_MEMORY;
    case ERROR_INVALID_BLOCK: return F_INVALID_BLOCK;
    case ERROR_BAD_ENVIRONMENT: return F_BAD_ENVIRONMENT;
    case ERROR_BAD_FORMAT: return F_BAD_FORMAT;
    case ERROR_INVALID_ACCESS: return F_INVALID_ACCESS;
    case ERROR_INVALID_DATA: return F_INVALID_DATA;
    case ERROR_OUTOFMEMORY: return F_OUTOFMEMORY;
    case ERROR_INVALID_DRIVE: return F_INVALID_DRIVE;
    case ERROR_CURRENT_DIRECTORY: return F_CURRENT_DIRECTORY;
    case ERROR_NOT_SAME_DEVICE: return F_NOT_SAME_DEVICE;
    case ERROR_NO_MORE_FILES: return F_NO_MORE_FILES;
    case ERROR_WRITE_PROTECT: return F_WRITE_PROTECT;
    case ERROR_BAD_UNIT: return F_BAD_UNIT;
    case ERROR_NOT_READY: return F_NOT_READY;
    case ERROR_BAD_COMMAND: return F_BAD_COMMAND;
    case ERROR_CRC: return F_CRC;
    case ERROR_BAD_LENGTH: return F_BAD_LENGTH;
    case ERROR_SEEK: return F_SEEK;
    case ERROR_NOT_DOS_DISK: return F_NOT_DOS_DISK;
    case ERROR_SECTOR_NOT_FOUND: return F_SECTOR_NOT_FOUND;
    case ERROR_OUT_OF_PAPER: return F_OUT_OF_PAPER;
    case ERROR_WRITE_FAULT: return F_WRITE_FAULT;
    case ERROR_READ_FAULT: return F_READ_FAULT;
    case ERROR_GEN_FAILURE: return F_GEN_FAILURE;
    case ERROR_SHARING_VIOLATION: return F_SHARING_VIOLATION;
    case ERROR_LOCK_VIOLATION: return F_LOCK_VIOLATION;
    case ERROR_WRONG_DISK: return F_WRONG_DISK;
    case ERROR_SHARING_BUFFER_EXCEEDED: return F_SHARING_BUFFER_EXCEEDED;
    case ERROR_HANDLE_EOF: return F_HANDLE_EOF;
    case ERROR_HANDLE_DISK_FULL: return F_HANDLE_DISK_FULL;
    case ERROR_NOT_SUPPORTED: return F_NOT_SUPPORTED;
    case ERROR_REM_NOT_LIST: return F_REM_NOT_LIST;
    case ERROR_DUP_NAME: return F_DUP_NAME;
